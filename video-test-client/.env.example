# Points at a running go-video instance (see ../go-video/README.md, "Develop").
VIDEO_SERVER_URL=http://localhost:3000
VIDEO_SERVER_SECRET=change-me

# Same Postgres go-video itself uses (DATABASE_URL in ../go-video/.env), so this
# client can insert the stub `video` row go-video's status updates write to,
# and poll that status. Point this at go-video's local dev DB
# (docker compose up -d db in ../go-video), NOT at the Next.js app's production DB.
DATABASE_URL=postgres://govideo:govideo@localhost:5432/govideo?sslmode=disable

# Same bucket go-video uploads to, so the finished render can be previewed here.
# For local dev, run go-video's `docker compose up -d minio minio-init` and
# point R2_ENDPOINT at it (see ../go-video/.env.example).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shorts
R2_ENDPOINT=http://localhost:9000
