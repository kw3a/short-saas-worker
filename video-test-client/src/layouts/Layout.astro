---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · go-video test client</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0b0d12;
        --panel: #151822;
        --border: #262b3a;
        --text: #e6e8ee;
        --muted: #8b93a7;
        --accent: #6ea8fe;
        --danger: #ff6b6b;
        --ok: #5fd68a;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }
      header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
      }
      header h1 { font-size: 1rem; margin: 0; color: var(--muted); font-weight: 600; }
      nav { display: flex; gap: 1rem; }
      nav a { color: var(--text); text-decoration: none; opacity: 0.7; }
      nav a[aria-current="page"] { opacity: 1; color: var(--accent); }
      main { max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
      }
      label { display: block; font-size: 0.85rem; color: var(--muted); margin: 1rem 0 0.35rem; }
      label:first-child { margin-top: 0; }
      input, select, textarea {
        width: 100%;
        background: #0e1017;
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 8px;
        padding: 0.55rem 0.65rem;
        font: inherit;
      }
      textarea { resize: vertical; min-height: 6rem; }
      .hint { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }
      .row { display: flex; gap: 0.75rem; align-items: center; }
      .checkbox-row { display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem; }
      .checkbox-row input { width: auto; }
      button {
        font: inherit;
        cursor: pointer;
        border-radius: 8px;
        border: 1px solid transparent;
      }
      button.primary {
        margin-top: 1.5rem;
        background: var(--accent);
        color: #0b0d12;
        font-weight: 600;
        padding: 0.65rem 1rem;
        width: 100%;
      }
      button.primary:disabled { opacity: 0.5; cursor: not-allowed; }
      button.ghost {
        background: transparent;
        border-color: var(--border);
        color: var(--text);
        padding: 0.35rem 0.6rem;
        font-size: 0.85rem;
      }
      .comment-row { display: flex; gap: 0.5rem; margin-top: 0.5rem; align-items: flex-start; }
      .comment-row textarea { min-height: 3rem; }
      #result { margin-top: 1.5rem; }
      #result:empty { display: none; }
      .status-line { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; }
      .dot { width: 0.6rem; height: 0.6rem; border-radius: 50%; background: var(--muted); }
      .dot.rendering { background: var(--accent); }
      .dot.completed { background: var(--ok); }
      .dot.failed { background: var(--danger); }
      .progress-row { display: flex; align-items: center; gap: 0.65rem; margin-top: 0.6rem; }
      progress { flex: 1; height: 0.6rem; appearance: none; border: none; border-radius: 999px; overflow: hidden; }
      progress::-webkit-progress-bar { background: var(--border); border-radius: 999px; }
      progress::-webkit-progress-value { background: var(--accent); border-radius: 999px; transition: width 0.3s ease; }
      progress::-moz-progress-bar { background: var(--accent); border-radius: 999px; }
      .progress-pct { font-size: 0.8rem; color: var(--muted); min-width: 2.5rem; text-align: right; }
      video, img { max-width: 100%; border-radius: 8px; margin-top: 0.75rem; display: block; }
      .error { color: var(--danger); font-size: 0.9rem; margin-top: 0.75rem; white-space: pre-wrap; }
    </style>
  </head>
  <body>
    <header>
      <h1>go-video test client</h1>
      <nav>
        <a href="/narration" aria-current={title === "Narration" ? "page" : undefined}>Narration</a>
        <a href="/askreddit" aria-current={title === "AskReddit" ? "page" : undefined}>AskReddit</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
