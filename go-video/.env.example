# Server
PORT=3000
VIDEO_SERVER_SECRET=change-me           # bearer token required on incoming requests
RENDER_WORKERS=2                        # concurrent render workers
ASSETS_DIR=.                            # dir containing Montserrat-ExtraBold.ttf, backgrounds/, musics/

# Postgres (same DB as the Next.js app)
# Local dev: docker compose up -d db
DATABASE_URL=postgres://govideo:govideo@localhost:5432/govideo?sslmode=disable

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shorts
# Local dev: docker compose up -d minio minio-init, then point at it here.
# R2_ACCESS_KEY_ID/R2_SECRET_ACCESS_KEY double as the MinIO root user/password.
R2_ENDPOINT=

# TTS microservice (Python / Azure Speech)
TTS_BASE_URL=http://localhost:3001
TTS_SECRET=                             # defaults to VIDEO_SERVER_SECRET if empty
